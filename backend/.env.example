# Copy to .env and set values. Never commit .env.

# Required. Postgres connection (Aiven, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Server port (default 3000)
PORT=3000

# Required in production. Min 32 chars for HS256.
JWT_SECRET=your-min-32-character-secret-here-change-in-production

# Optional. Comma-separated origins for CORS (default * in dev)
# CORS_ORIGINS=https://yourapp.com,https://admin.yourapp.com

# Optional. Set to "production" to hide stack traces and tighten security
NODE_ENV=development

# Twilio Verify (SMS OTP)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email – verification and password-reset. Prefer Resend on Render (SMTP often blocked).
# Resend (recommended on Render): https://resend.com – set RESEND_API_KEY and optional MAIL_FROM (e.g. onboarding@resend.dev).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# MAIL_FROM=onboarding@resend.dev

# SMTP (Gmail, SendGrid, etc.). If RESEND_API_KEY is set, Resend is used instead.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# MAIL_FROM=noreply@yourdomain.com

# If neither Resend nor SMTP is configured, codes are only logged to the server console (dev).
