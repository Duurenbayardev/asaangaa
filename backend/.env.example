# Copy to .env and set values. Never commit .env.

# Required. Postgres connection (Aiven, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Server port (default 3000)
PORT=3000

# Required in production. Min 32 chars for HS256.
JWT_SECRET=your-min-32-character-secret-here-change-in-production

# Optional. Comma-separated origins for CORS (default * in dev)
# CORS_ORIGINS=https://yourapp.com,https://admin.yourapp.com

# Optional. Set to "production" to hide stack traces and tighten security
NODE_ENV=development

# Firebase Admin (for phone verification). Get from Firebase Console > Project settings > Service accounts.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
