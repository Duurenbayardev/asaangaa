# Copy to .env and set values. Never commit .env.

# Required. Postgres connection (Aiven, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Server port (default 3000)
PORT=3000

# Required in production. Min 32 chars for HS256.
JWT_SECRET=your-min-32-character-secret-here-change-in-production

# Optional. Comma-separated origins for CORS (default * in dev)
# CORS_ORIGINS=https://yourapp.com,https://admin.yourapp.com

# Optional. Set to "production" to hide stack traces and tighten security
NODE_ENV=development

# Optional. Directory for product image uploads. Default: backend/uploads (lost on restart when deployed).
# On Render: add a Persistent Disk, mount at /data, then set UPLOAD_DIR=/data/uploads so images survive deploys/restarts.
# UPLOAD_DIR=/data/uploads

# Email verification. For deployed (e.g. Render) use Resend (SMTP is often blocked). For local, SMTP or leave unset to log code.
# Resend (recommended on Render): get API key at https://resend.com — emails send from onboarding@resend.dev until you verify a domain
# RESEND_API_KEY=re_xxxxxxxxxxxx
# SMTP (local only): Gmail etc. often blocked from cloud IPs
# MAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Admin notifications (order alerts)
# ADMIN_MAIL=admin@example.com

# QPay Mongolia (payments). Get credentials from info@qpay.mn
# QPAY_BASE_URL=https://merchant-sandbox.qpay.mn
# QPAY_CLIENT_ID=your_client_id
# QPAY_CLIENT_SECRET=your_client_secret
# QPAY_INVOICE_CODE=TEST_INVOICE
# Local LAN example: QPAY_CALLBACK_BASE_URL=http://192.168.0.102:3000
# QPAY_CALLBACK_BASE_URL=https://your-backend-url.com
