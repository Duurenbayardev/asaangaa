EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Sign-In (optional): create OAuth 2.0 Web client in Google Cloud Console,
# add redirect URI from app (e.g. https://auth.expo.io/@yourusername/Asanga or your custom scheme).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Backend .env: same Google client ID/secret for token exchange
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Backend: optional SMTP for OTP emails (if not set, OTP is logged to console)
# MAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
