EXPO_PUBLIC_API_URL=http://localhost:3000

# Logo.dev: publishable key for bank/company logos (client-safe). Get from https://www.logo.dev/dashboard/api-keys
# Secret key (sk_...) is for server-side only; do not put it in the app.
EXPO_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=pk_your_key_here

# Backend: optional SMTP for OTP emails (if not set, OTP is logged to console)
# MAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
