{
  "expo": {
    "name": "Asanga",
    "slug": "Asanga",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app icon.jpg",
    "scheme": "asanga",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asaangaa.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Бүтээгдэхүүний зургийг сонгоход шаардлагатай.",
        "NSCameraUsageDescription": "Бүтээгдэхүүний зургийг авахад шаардлагатай."
      }
    },
    "android": {
      "package": "com.asaangaa.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/app icon.jpg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/app icon.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app icon.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Бүтээгдэхүүний зургийг сонгоход шаардлагатай.",
          "cameraPermission": "Бүтээгдэхүүний зургийг авахад шаардлагатай."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
